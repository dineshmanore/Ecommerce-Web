# MongoDB Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
SPRING_DATA_MONGODB_URI=mongodb+srv://dinesh:D9075134498m@cluster0.sizscn5.mongodb.net/ecommerce
# JWT Secret for token generation (must be at least 256 bits)
# Generate a strong one: openssl rand -base64 32
JWT_SECRET=abc123

# CORS Origins (comma-separated)
# Local dev: http://localhost:5173,http://localhost:3000
# Production: https://your-vercel-domain.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server Port
PORT=8080

# Spring Profiles (dev or prod)
SPRING_PROFILES_ACTIVE=prod
